{
  "swagger": "2.0",
  "info": {
    "title": "World Cup Kits API",
    "description": "API documentation for the World Cup Kits e-commerce shop (Final Project). It manages products, users, orders, and reviews.",
    "version": "1.0.0"
  },
  "host": "world-cup-kits-wi9b.onrender.com",
  "basePath": "/",
  "tags": [
    {
      "name": "Products",
      "description": "Operations related to product inventory"
    },
    {
      "name": "Users",
      "description": "Operations related to user profiles"
    },
    {
      "name": "Orders",
      "description": "Operations related to orders"
    }
  ],
  "schemes": ["https"],
  "securityDefinitions": {
    "github_auth": {
      "type": "oauth2",
      "authorizationUrl": "/login",
      "flow": "implicit",
      "scopes": {}
    }
  },
  "paths": {
    "/products": {
      "get": {
        "tags": ["Products"],
        "description": "Retrieves an array containing all products available in the shop.",
        "responses": {
          "200": {
            "description": "A list of products successfully retrieved."
          },
          "500": { "description": "Internal Server Error." }
        }
      },
      "post": {
        "tags": ["Products"],
        "description": "Creates a new product record. Only admins can perform this action.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Product" }
          }
        ],
        "responses": {
          "201": { "description": "Product Created successfully." },
          "400": { "description": "Bad Request - Validation failed." },
          "401": { "description": "Unauthorized." },
          "500": { "description": "Internal Server Error." }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "description": "Retrieves a single product by its MongoDB ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Product found and returned." },
          "400": { "description": "Bad Request - Invalid ID format." },
          "404": { "description": "Product Not Found." },
          "500": { "description": "Internal Server Error." }
        }
      },
      "put": {
        "tags": ["Products"],
        "description": "Updates an existing product by its ID.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Product" }
          }
        ],
        "responses": {
          "204": {
            "description": "Product successfully updated (No Content returned)."
          },
          "400": { "description": "Bad Request." },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Product Not Found." },
          "500": { "description": "Internal Server Error." }
        }
      },
      "delete": {
        "tags": ["Products"],
        "description": "Deletes a product by its ID.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": { "description": "Product successfully deleted." },
          "400": { "description": "Bad Request." },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Product Not Found." },
          "500": { "description": "Internal Server Error." }
        }
      }
    },
  "definitions": {
    "Product": {
      "type": "object",
      "required": [
        "name",
        "description",
        "price",
        "stock",
        "team",
        "year",
        "sizes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "example": "Italy 2006 Home Kit"
        },
        "description": {
          "type": "string",
          "example": "The iconic blue jersey worn by Italy during their victorious 2006 World Cup campaign."
        },
        "price": {
          "type": "number",
          "example": 89.99
        },
        "stock": {
          "type": "integer",
          "example": 15
        },
        "team": {
          "type": "string",
          "example": "Italy"
        },
        "year": {
          "type": "integer",
          "example": 2006
        },
        "sizes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["S", "M", "L", "XL"]
        }
      }
    },
    "User": {
      "type": "object",
      "required": ["name", "email", "role", "provider", "providerId"],
      "properties": {
        "name": {
          "type": "string",
          "example": "Luca Carlo"
        },
        "email": {
          "type": "string",
          "example": "luca.carlo@example.com"
        },
        "role": {
          "type": "string",
          "example": "admin"
        },
        "provider": {
          "type": "string",
          "example": "github"
        },
        "providerId": {
          "type": "string",
          "example": "git_987654321"
        }
      }
    }
  }
}

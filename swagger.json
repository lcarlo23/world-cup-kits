{
  "swagger": "2.0",
  "info": {
    "title": "World Cup Kits API",
    "description": "API documentation for the World Cup Kits e-commerce shop (Final Project). It manages products, users, orders, and reviews.",
    "version": "1.0.0"
  },
  "host": "",
  "basePath": "/",
  "tags": [
    {
      "name": "Products",
      "description": "Operations related to product inventory"
    },
    { "name": "Users", "description": "Operations related to user profiles" },
    { "name": "Orders", "description": "Operations related to orders" },
    {
      "name": "Reviews",
      "description": "Operations related to product reviews"
    }
  ],
  "schemes": ["http", "https"],
  "securityDefinitions": {
    "github_auth": {
      "type": "oauth2",
      "authorizationUrl": "/login",
      "flow": "implicit",
      "scopes": {}
    }
  },
  "paths": {
    "/products/": {
      "get": {
        "tags": ["Products"],
        "description": "Retrieves an array containing all products.",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Products"],
        "description": "Creates a new product.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Product" }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "description": "Retrieves a single product by ID.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Products"],
        "description": "Updates an existing product.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Product" }
          }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "description": "Deletes a product.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/users/": {
      "get": {
        "tags": ["Users"],
        "description": "Retrieves all users.",
        "security": [{ "github_auth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Users"],
        "description": "Registers a new user.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/User" }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "description": "Retrieves a single user by ID.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Users"],
        "description": "Updates a user profile.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/User" }
          }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "description": "Deletes a user.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/orders/": {
      "get": {
        "tags": ["Orders"],
        "description": "Retrieves orders for the logged-in user (or all if admin).",
        "security": [{ "github_auth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Orders"],
        "description": "Creates a new order for the logged-in user.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Order" }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "description": "Retrieves a single order by ID.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Orders"],
        "description": "Updates an order.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Order" }
          }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Orders"],
        "description": "Deletes an order.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/": {
      "get": {
        "tags": ["Reviews"],
        "description": "Retrieves all reviews.",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Reviews"],
        "description": "Creates a new review.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Review" }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/{id}": {
      "get": {
        "tags": ["Reviews"],
        "description": "Retrieves a single review by ID.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Reviews"],
        "description": "Updates a review.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Review" }
          }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Reviews"],
        "description": "Deletes a review.",
        "security": [{ "github_auth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  },
  "definitions": {
    "Product": {
      "type": "object",
      "required": [
        "name",
        "description",
        "price",
        "stock",
        "team",
        "year",
        "sizes"
      ],
      "properties": {
        "name": { "type": "string", "example": "Italy 2006 Home Kit" },
        "description": {
          "type": "string",
          "example": "The iconic blue jersey worn by Italy."
        },
        "price": { "type": "number", "example": 89.99 },
        "stock": { "type": "integer", "example": 15 },
        "team": { "type": "string", "example": "Italy" },
        "year": { "type": "integer", "example": 2006 },
        "sizes": {
          "type": "array",
          "items": { "type": "string" },
          "example": ["S", "M", "L", "XL"]
        }
      }
    },
    "User": {
      "type": "object",
      "required": ["name", "email", "role", "provider", "providerId"],
      "properties": {
        "name": { "type": "string", "example": "Luca Carlo" },
        "email": { "type": "string", "example": "luca.carlo@example.com" },
        "role": { "type": "string", "example": "admin" },
        "provider": { "type": "string", "example": "github" },
        "providerId": { "type": "string", "example": "git_987654321" }
      }
    },
    "Order": {
      "type": "object",
      "required": ["status", "items", "totalPrice"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "team": { "type": "string", "example": "Italy" },
              "size": { "type": "string", "example": "L" },
              "jerseyName": { "type": "string", "example": "Buffon" },
              "number": { "type": "integer", "example": 1 },
              "price": { "type": "number", "example": 89.99 },
              "quantity": { "type": "integer", "example": 1 }
            }
          }
        },
        "totalPrice": { "type": "number", "example": 89.99 }
      }
    },
    "Review": {
      "type": "object",
      "required": ["productName", "rating", "comment"],
      "properties": {
        "productName": {
          "type": "string",
          "example": "Italy Home Jersey 2006"
        },
        "rating": { "type": "integer", "example": 5 },
        "comment": {
          "type": "string",
          "example": "The stitch quality is amazing!"
        }
      }
    }
  }
}
